@section Scripts{
	<script>
		function loadCount(url, elementId) {
			$.get(url, function (data) {
				if (elementId === "feesAmount") {
					$('#' + elementId).text("₹ " + data);
				} else {
					$('#' + elementId).text(data);
				}
			});
		}

		function loadGenderCount() {
			$.get('/Student/GetGenderCount', function (data) {
				$('#maleCount').text(data.male);
				$('#femaleCount').text(data.female);
			});
		}

		function loadRoomStatus() {
			$.get('/Room/GetRoomStatusCount', function (data) {
				$('#availableCount').text(data.available);
				$('#occupiedCount').text(data.occupied);
				$('#maintenanceCount').text(data.maintenance);
			});
		}

		function loadAttendanceCount() {
			$.get('/StudentAttendance/GetAttendanceCount', function (data) {

				$('#presentCount').text(data.present);

				$('#absentCount').text(data.absent);

			});
		}

		function loadComplaintStatusCount() {

			$.get('/Complaint/GetComplaintStatusCount', function (data) {

				$('#pendingCount').text(data.pending);

				$('#inprogressCount').text(data.inprogress);

				$('#resolvedCount').text(data.resolved);

			});

		}

		function loadUserCount() {

			$.get('/UserView/GetUserCount', function (data) {

				$('#developerCount').text(data.developer);

				$('#studentUserCount').text(data.student);

				$('#wardenUserCount').text(data.warden);

				$('#activeCount').text(data.active);

				$('#inactiveCount').text(data.inactive);

			});

		}





		// Show button when scroll down
		$(window).scroll(function () {
			if ($(this).scrollTop() > 200) {
				$('#scrollTopBtn').fadeIn();
			} else {
				$('#scrollTopBtn').fadeOut();
			}
		});

		// Scroll to top when clicked
		$('#scrollTopBtn').click(function () {
			$('html, body').animate({ scrollTop: 0 }, 600);
			return false;
		});

		
		// Student Fees Line Chart
				function loadStudentFeesLineChart() {

			$.get('/Fees/GetFeesChartData', function (data) {

				var ctx = document.getElementById('canvas-lineCharts').getContext('2d');

				if (window.simpleLineChart) {
					window.simpleLineChart.destroy();
				}

				window.simpleLineChart = new Chart(ctx, {

					type: 'line',

					data: {

						labels: data.labels,

						datasets: [{

							data: data.values,

							borderColor: 'blue',

							backgroundColor: 'rgba(0,0,255,0.1)',

							fill: true,

							tension: 0.3

						}]
					},

					options: {

						responsive: true,

						plugins: {

							legend: { display: false }

						},

						scales: {

							y: { beginAtZero: true }
						}
					}
				});
			});
		}

		

		// ✅ Student Attendance Pie Chart
		
		function loadAttendancePieChart() {

			$.get('/StudentAttendance/GetAttendanceByStatus', function (data) {

				var status = [];
				var total = [];
				var colors = [];

				data.forEach(function (item) {

					status.push(item.status);
					total.push(item.total);

					if (item.status === "Present")
						colors.push("#28a745"); // Green

					else if (item.status === "Absent")
						colors.push("#dc3545"); // Red

					else
						colors.push("#ffc107"); // Yellow

				});

				var ctx = document.getElementById('canvas-pieChart');

				if (!ctx) return;

				if (window.attendancePieChart)
					window.attendancePieChart.destroy();

				window.attendancePieChart = new Chart(ctx, {

					type: 'pie',

					data: {

						labels: status,

						datasets: [{
							data: total,
							backgroundColor: colors
						}]

					},

					options: {

						responsive: true,

						plugins: {

							legend: {
								position: 'bottom'
							}

						}

					}

				});

			});

		}


		
	    // ✅ User Role Status Pie Chart
		function loadUserRoleStatusPieChart() {

			$.get('/UserView/GetUserRoleStatusPieChart', function (data) {

				var ctx = document.getElementById('userRoleStatusPieChart');

				if (!ctx) return;

				if (window.userRoleChart)
					window.userRoleChart.destroy();

				window.userRoleChart = new Chart(ctx, {

					type: 'pie',

					data: {

						labels: [

							'Active Developer',
							'Inactive Developer',

							'Active Student',
							'Inactive Student',

							'Active Warden',
							'Inactive Warden'

						],

						datasets: [{

							data: [

								data.activeDeveloper,
								data.inactiveDeveloper,

								data.activeStudent,
								data.inactiveStudent,

								data.activeWarden,
								data.inactiveWarden

							],

							backgroundColor: [

								'#28a745',   // Green
								'#dc3545',   // Red

								'#007bff',   // Blue
								'#ffc107',   // Yellow

								'#6f42c1',   // Purple
								'#fd7e14'    // Orange

							]

						}]

					},

					options: {

						responsive: true,

						plugins: {

							legend: {

								position: 'bottom'

							}

						}

					}

				});

			});

		}
		


		












		function refreshAll() {
			loadCount('/Student/GetStudentCount', 'studentCount');
			loadCount('/Visitor/GetVisitorCount', 'visitorCount');
			loadCount('/Warden/GetWardenCount', 'wardenCount');
			loadCount('/Fees/GetTotalFeesAmount', 'feesAmount');
			loadGenderCount(); // 👈 Added here
			loadRoomStatus();
			loadStudentFeesLineChart();
			

			loadAttendancePieChart(); //pie att

			
			loadUserRoleStatusPieChart(); // occupied user
			
			loadAttendanceCount(); // 👈 ADD THIS LINE
			loadComplaintStatusCount();
			loadUserCount();
			loadBarChart();
			

		}

		refreshAll();
		setInterval(refreshAll, 5000);
	</script>
}
@* -------------------------------------------------------------------- *@