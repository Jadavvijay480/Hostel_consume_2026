
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

<h2 class="text-success text-center">Welcome Hostel ERP Dashboard</h2>

<div class="d-flex justify-content-between mb-3">
	<h3> Welcome, @Context.Session.GetString("FullName")</h3>

	@* <a asp-controller="Account" asp-action="Logout" class="btn btn-success"> Logout </a> *@
</div>



<div class="app-content pt-3 p-md-3 p-lg-4">

	<div class="container-xl">

		<h1 class="app-page-title">Dashboard</h1>

		<div class="app-card alert alert-dismissible shadow-sm mb-4 border-left-decoration" role="alert">

			<div class="inner">
				<div class="app-card-body p-3 p-lg-4">
					<h3 class="mb-3">Welcome, Hostel-ERP!</h3>
					<div class="row gx-5 gy-3">
						<div class="col-12 col-lg-9">

							<div>
								Welcome to Hostel-ERP
								Smart Management for Students, Rooms, and Fees in One Place.
							</div>
						</div><!--//col-->
						<div class="col-12 col-lg-3">
							<a class="btn app-btn-primary" >
								<svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-file-earmark-arrow-down me-2" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
									<path d="M4 0h5.5v1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h1V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2z" />
									<path d="M9.5 3V0L14 4.5h-3A1.5 1.5 0 0 1 9.5 3z" />
									<path fill-rule="evenodd" d="M8 6a.5.5 0 0 1 .5.5v3.793l1.146-1.147a.5.5 0 0 1 .708.708l-2 2a.5.5 0 0 1-.708 0l-2-2a.5.5 0 1 1 .708-.708L7.5 10.293V6.5A.5.5 0 0 1 8 6z" />
								</svg>Free Download
							</a>
						</div><!--//col-->
					</div><!--//row-->
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
				</div><!--//app-card-body-->

			</div><!--//inner-->

		</div><!--//app-card-->


		@* -------------------------------------------- *@
		<div class="row g-4 mb-4">

			@* -----Total students--- *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">
						<h4 class="stats-type mb-1">Total students</h4>
						@* <div class="stats-figure">$12,628</div> *@
						<div class="stats-meta text-success fs-4 fw-bold text-primary" id="studentCount">
							<svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-arrow-up" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
								<path fill-rule="evenodd" d="M8 15a.5.5 0 0 0 .5-.5V2.707l3.146 3.147a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708L7.5 2.707V14.5a.5.5 0 0 0 .5.5z" />
							</svg> 0
						</div>
					</div><!--//app-card-body-->
					<a class="app-card-link-mask" href="#"></a>
				</div><!--//app-card-->
			</div><!--//col-->

			
				
			@* ------Total visitors----- *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">
						<h4 class="stats-type mb-1">Total Visitors</h4>
						@* <div class="stats-figure">$12,628</div> *@
						<div class="stats-meta text-success fs-4 fw-bold text-primary" id="visitorCount">
							<svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-arrow-up" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
								<path fill-rule="evenodd" d="M8 15a.5.5 0 0 0 .5-.5V2.707l3.146 3.147a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708L7.5 2.707V14.5a.5.5 0 0 0 .5.5z" />
							</svg> 0
						</div>
					</div><!--//app-card-body-->
					<a class="app-card-link-mask" href="#"></a>
				</div><!--//app-card-->
			</div><!--//col-->
			
			@* ----Total Warden---- *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">
						<h4 class="stats-type mb-1">Total Wardens</h4>
						@* <div class="stats-figure">$12,628</div> *@
						<div class="stats-meta text-success fs-4 fw-bold text-primary" id="wardenCount">
							<svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-arrow-up" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
								<path fill-rule="evenodd" d="M8 15a.5.5 0 0 0 .5-.5V2.707l3.146 3.147a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708L7.5 2.707V14.5a.5.5 0 0 0 .5.5z" />
							</svg> 0
						</div>
					</div><!--//app-card-body-->
					<a class="app-card-link-mask" href="#"></a>
				</div><!--//app-card-->
			</div><!--//col-->

			@* ----Total Fees amount count ---- *@

			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">
						<h4 class="stats-type mb-1">Total Fees Amount</h4>

						<div class="stats-meta fs-4 fw-bold text-success" id="feesAmount">
							₹ 0
						</div>
					</div>
					<a class="app-card-link-mask" href="#"></a>
				</div>
			</div>


			@* ---------✅ Male + Female in ONE Card------------- *@

			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">

						<h4 class="stats-type mb-3">Students Gender</h4>

						<div class="d-flex justify-content-between">

							<div>
								<span class="text-success fw-semibold">Male :</span>
								<div class="fs-5 fw-bold text-success" id="maleCount">0</div>
							</div>

							<div>
								<span class="text-danger fw-semibold">Female :</span>
								<div class="fs-5 fw-bold text-danger" id="femaleCount">0</div>
							</div>

						</div>

					</div>
				</div>
			</div>

			 @* -----------room 🟢 Available🔴 Occupied🟡 Maintenance--------- *@

			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">

						<h4 class="stats-type mb-3">Room Status</h4>

						<div class="d-flex justify-content-between text-center">

							<div>
								<div class="fw-semibold text-success">Avl :</div>
								<div class="fs-5 fw-bold text-success" id="availableCount">0</div>
							</div>

							<div>
								<div class="fw-semibold text-danger">Occ. :</div>
								<div class="fs-5 fw-bold text-danger" id="occupiedCount">0</div>
							</div>

							<div>
								<div class="fw-semibold text-warning">Maint :</div>
								<div class="fs-5 fw-bold text-warning" id="maintenanceCount">0</div>
							</div>

						</div>

					</div>
				</div>
			</div>
			@* -------------------------------------------------------------------- *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">

						<h4 class="stats-type mb-3">Students Attendance</h4>

						<div class="d-flex justify-content-between">

							<div>
								<span class="text-success fw-semibold">Present :</span>
								<div class="fs-5 fw-bold text-success" id="presentCount">0</div>
							</div>

							<div>
								<span class="text-danger fw-semibold">Absent :</span>
								<div class="fs-5 fw-bold text-danger" id="absentCount">0</div>
							</div>

						</div>

					</div>
				</div>
			</div>

			@* ------------------------------------------------------------------------ *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">

					<div class="app-card-body p-3 p-lg-4">

						<h4 class="stats-type mb-2">Complaints</h4>

						<div class="fs-6 fw-bold text-danger">
							Pending :
							<span id="pendingCount">0</span>
						</div>

						<div class="fs-6 fw-bold text-warning">
							In Progress :
							<span id="inprogressCount">0</span>
						</div>

						<div class="fs-6 fw-bold text-success">
							Resolved :
							<span id="resolvedCount">0</span>
						</div>

					</div>

				</div>
			</div>
			@* ---------------------------------------------------------------------- *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">

					<div class="app-card-body p-3 p-lg-4">

						<h4 class="stats-type mb-2">Users</h4>

						<div class="text-success fw-bold">
							Developer :
							<span id="developerCount">0</span>
						</div>

						<div class="text-warning fw-bold">
							Student :
							<span id="studentUserCount">0</span>
						</div>

						<div class="text-danger fw-bold">
							Warden :
							<span id="wardenUserCount">0</span>
						</div>

					</div>

				</div>
			</div>
			@* -------------------------------------------------------------- *@
			<div class="col-6 col-lg-3">
				<div class="app-card app-card-stat shadow-sm h-100">
					<div class="app-card-body p-3 p-lg-4">

						<h4 class="stats-type mb-3">Users</h4>

						<div class="d-flex justify-content-between">

							<div class="text-success fw-bold">
								Active :
								<span id="activeCount">0</span>
							</div>

							<div class="text-danger fw-bold">
								Inactive :
								<span id="inactiveCount">0</span>
							</div>

						</div>

					</div>
				</div>
			</div>
			
			
	 
		</div><!--//row-->
		@* -------------------------------------------- *@






		<div class="row g-4 mb-4">

			@* ---------------------Line Chart Example-------------------- *@

			<div class="col-12 col-lg-6">
				<div class="app-card app-card-chart h-100 shadow-sm">
					<div class="app-card-header p-3">
						<div class="row justify-content-between align-items-center">
							<div class="col-auto">
								<h4 class="app-card-title">Line Chart Fees Month</h4>
							</div><!--//col-->
						</div><!--//row-->
					</div><!--//app-card-header-->
					<div class="app-card-body p-3 p-lg-4">
						<div class="mb-3 d-flex">
							<select class="form-select form-select-sm ms-auto d-inline-flex w-auto">
								<option value="1" selected>This week</option>
								<option value="2">Today</option>
								<option value="3">This Month</option>
								<option value="3">This Year</option>
							</select>
						</div>
						<div class="chart-container">
							
							<canvas id="canvas-lineCharts"></canvas>
						</div>
					</div><!--//app-card-body-->
				</div><!--//app-card-->
			</div><!--//col-->
			


			@* ---------------------Line Chart Example end -------------------- *@
			

			@* ---------------------Bar  Chart Example -------------------- *@
			<div class="col-12 col-lg-6">
				<div class="app-card app-card-chart h-100 shadow-sm">
					<div class="app-card-header p-3">
						<div class="row justify-content-between align-items-center">
							<div class="col-auto">
								<h4 class="app-card-title">Bar Chart Fees Status</h4>
							</div><!--//col-->
						</div><!--//row-->
					</div><!--//app-card-header-->
					<div class="app-card-body p-3 p-lg-4">
						<div class="mb-3 d-flex">
							<select class="form-select form-select-sm ms-auto d-inline-flex w-auto">
								<option value="1" selected>This week</option>
								<option value="2">Today</option>
								<option value="3">This Month</option>
								<option value="3">This Year</option>
							</select>
						</div>
						<div class="chart-container">
							<canvas id="canvas-barCharts"></canvas>
						</div>
					</div><!--//app-card-body-->
				</div><!--//app-card-->
			</div><!--//col-->
		
			@* ---------------------Bar  Chart Example  end-------------------- *@


			@* ------------------pie chart--------------- *@
			<div class="col-12 col-lg-6">
				<div class="app-card app-card-chart h-100 shadow-sm">
					<div class="app-card-header p-3">
						<div class="row justify-content-between align-items-center">
							<div class="col-auto">
								<h4 class="app-card-title">Pie Chart Student Attendance Status</h4>
							</div><!--//col-->
						</div><!--//row-->
						<div class="app-card-body p-3 p-lg-4">
							<div class="mb-3 d-flex">
								<select class="form-select form-select-sm ms-auto d-inline-flex w-auto">
									<option value="1" selected>This week</option>
									<option value="2">Today</option>
									<option value="3">This Month</option>
									<option value="3">This Year</option>
								</select>
							</div>
							<div class="chart-container">
								
								<canvas id="canvas-pieChart"></canvas>
							</div>
						</div><!--//app-card-body-->
					</div><!--//app-card-header-->
				</div>
			</div>
			@* ---------------------------- *@

			@* ------------------pie chart  user --------------- *@
			<div class="col-12 col-lg-6">
				<div class="app-card app-card-chart h-100 shadow-sm">
					<div class="app-card-header p-3">
						<div class="row justify-content-between align-items-center">
							<div class="col-auto">
								<h4 class="app-card-title">User Role Active / Inactive Chart</h4>
								<h4></h4>
							</div><!--//col-->
						</div><!--//row-->
						<div class="app-card-body p-3 p-lg-4">
							<div class="mb-3 d-flex">
								<select class="form-select form-select-sm ms-auto d-inline-flex w-auto">
									<option value="1" selected>This week</option>
									<option value="2">Today</option>
									<option value="3">This Month</option>
									<option value="3">This Year</option>
								</select>
							</div>
							<div class="chart-container">
								@* <canvas id="userPieChart"></canvas> *@
								<canvas id="userRoleStatusPieChart"></canvas>
							</div>
						</div><!--//app-card-body-->
					</div><!--//app-card-header-->
				</div>
			</div>

		
			@* ---------------------------- *@

		</div><!--//row-->


		<div class="row g-4 mb-4">
			@* ---------------------Progress  Chart Example -------------------- *@

			<div class="col-12 col-lg-6">
				<div class="app-card app-card-progress-list h-100 shadow-sm">
					<div class="app-card-header p-3">
						<div class="row justify-content-between align-items-center">
							<div class="col-auto">
								<h4 class="app-card-title"> Students Progress</h4>
							</div><!--//col-->
						</div><!--//row-->
					</div><!--//app-card-header-->
					<div class="app-card-body">
						<div class="item p-3">

							<!-- Male -->
							<div class="mb-3">
								<div class="title mb-1">Male</div>

								<div class="progress">
									<div id="maleBar"
										 class="progress-bar bg-danger"
										 style="width:0%">
									</div>
								</div>

								<small id="maleText"></small>
							</div>


							<!-- Female -->
							<div>

								<div class="title mb-1">Female</div>

								<div class="progress">
									<div id="femaleBar"
										 class="progress-bar bg-success"
										 style="width:0%">
									</div>
								</div>

								<small id="femaleText"></small>

							</div>

						</div>
						


						

						

						

					</div><!--//app-card-body-->
				</div><!--//app-card-->
			</div><!--//col-->

			
			@* ---------------------Progress  Chart Example  end-------------------- *@

			@* ---------------------Stats List  Chart Example -------------------- *@
			<div class="col-12 col-lg-6">
				<div class="app-card app-card-stats-table h-100 shadow-sm">
					<div class="app-card-header p-3">
						<div class="row justify-content-between align-items-center">
							<div class="col-auto">
								<h4 class="app-card-title">Visitors  List</h4>
							</div><!--//col-->
						</div><!--//row-->
					</div><!--//app-card-header-->
					<div class="app-card-body p-3 p-lg-4">
						<div class="table-responsive">
							<table class="table table-borderless mb-0">
								<thead>
									<tr>
										<th class="meta">Source</th>
										<th class="meta stat-cell">Views</th>
										<th class="meta stat-cell">Today</th>
									</tr>
								</thead>
								<tbody>

									<tr>
										<td>Total Visitors</td>
										<td class="stat-cell" id="totalVisitor"></td>
										<td class="stat-cell">100%</td>
									</tr>

									<tr>
										<td>Today Visitors</td>
										<td class="stat-cell" id="todayVisitor"></td>
										<td class="stat-cell text-success">Today</td>
									</tr>

									<tr>
										<td>Inside Hostel</td>
										<td class="stat-cell" id="insideVisitor"></td>
										<td class="stat-cell text-warning">Active</td>
									</tr>

									<tr>
										<td>Exited Visitors</td>
										<td class="stat-cell" id="outsideVisitor"></td>
										<td class="stat-cell text-danger">Out</td>
									</tr>

								</tbody>
							</table>
						</div><!--//table-responsive-->
					</div><!--//app-card-body-->
				</div><!--//app-card-->
			</div><!--//col-->

			
			@* ---------------------Stats List  Chart Example  end -------------------- *@


		</div><!--//row-->

		@* ----------------------------card bottom------------- *@
		<div class="row g-4 mb-4">
			<div class="col-12 col-lg-4">
				<div class="app-card app-card-basic d-flex flex-column align-items-start shadow-sm">
					<div class="app-card-header p-3 border-bottom-0">
						<div class="row align-items-center gx-3">
							<div class="col-auto">
								<div class="app-icon-holder">
									<svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-receipt" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
										<path fill-rule="evenodd" d="M1.92.506a.5.5 0 0 1 .434.14L3 1.293l.646-.647a.5.5 0 0 1 .708 0L5 1.293l.646-.647a.5.5 0 0 1 .708 0L7 1.293l.646-.647a.5.5 0 0 1 .708 0L9 1.293l.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .801.13l.5 1A.5.5 0 0 1 15 2v12a.5.5 0 0 1-.053.224l-.5 1a.5.5 0 0 1-.8.13L13 14.707l-.646.647a.5.5 0 0 1-.708 0L11 14.707l-.646.647a.5.5 0 0 1-.708 0L9 14.707l-.646.647a.5.5 0 0 1-.708 0L7 14.707l-.646.647a.5.5 0 0 1-.708 0L5 14.707l-.646.647a.5.5 0 0 1-.708 0L3 14.707l-.646.647a.5.5 0 0 1-.801-.13l-.5-1A.5.5 0 0 1 1 14V2a.5.5 0 0 1 .053-.224l.5-1a.5.5 0 0 1 .367-.27zm.217 1.338L2 2.118v11.764l.137.274.51-.51a.5.5 0 0 1 .707 0l.646.647.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.509.509.137-.274V2.118l-.137-.274-.51.51a.5.5 0 0 1-.707 0L12 1.707l-.646.647a.5.5 0 0 1-.708 0L10 1.707l-.646.647a.5.5 0 0 1-.708 0L8 1.707l-.646.647a.5.5 0 0 1-.708 0L6 1.707l-.646.647a.5.5 0 0 1-.708 0L4 1.707l-.646.647a.5.5 0 0 1-.708 0l-.509-.51z" />
										<path fill-rule="evenodd" d="M3 4.5a.5.5 0 0 1 .5-.5h6a.5.5 0 1 1 0 1h-6a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 1 1 0 1h-6a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 1 1 0 1h-6a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zm8-6a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5z" />
									</svg>
								</div><!--//icon-holder-->

							</div><!--//col-->
							<div class="col-auto">
								<h4 class="app-card-title">Students</h4>
							</div><!--//col-->
						</div><!--//row-->
					</div><!--//app-card-header-->
					<div class="app-card-body px-4">

						<div class="intro">
							Student Card
						</div>
