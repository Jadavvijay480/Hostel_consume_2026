@model IEnumerable<Hostel_Consume_2026.Models.UserModel>

@{
    ViewData["Title"] = "User List";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            title: "Success!",
            text: "@TempData["Success"]",
            icon: "success",
            position: "top",
            timer: 2000,
            timerProgressBar: true,
            showConfirmButton: false
        });
    </script>
}

<div class="container mt-5">
    <div class="card shadow-lg">

        <!-- HEADER -->
        <div class="card-header bg-success text-white">
            <div class="row align-items-center">

                <!-- TITLE -->
                <div class="col-md-4">
                    <h4 class="mb-0 text-white">👤 User Record</h4>
                </div>

                <!-- SEARCH -->
                <div class="col-md-4 text-center">
                    <div class="input-group input-group-sm justify-content-center" style="max-width:300px;">

                        <input type="text"
                               class="form-control"
                               id="searchInput"
                               placeholder="Search User">

                        <button class="btn btn-light"
                                id="searchBtn">

                            🔍

                        </button>

                    </div>
                </div>

                <!-- BUTTON -->
                <div class="col-md-4 text-end">

                    <a asp-action="ExportToExcel"
                       class="btn btn-light btn-sm me-2">

                        ⬇ Excel

                    </a>

                    <a asp-action="Add"
                       class="btn btn-light btn-sm">

                        + Add User

                    </a>

                </div>

            </div>
        </div>


        <!-- BODY -->
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover text-center"
                       id="userTable">

                    <thead class="table-secondary">

                        <tr>

                            <th>UserID</th>

                            <th>FullName</th>

                            <th>Email</th>

                            <th>Password</th>

                            <th>MobileNo</th>

                            <th>Created</th>

                            <th>UpdatedAt</th>

                            <th>Role</th>

                            <th>IsActive</th>


                            <th width="190">Actions</th>

                        </tr>

                    </thead>


                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var user in Model)
                            {

                                <tr>

                                    <td>@user.UserId</td>

                                    <td>@user.FullName</td>

                                    <td>@user.Email</td>
                                    <td>@user.Password</td>

                                    <td>@user.MobileNo</td>

                      

                                    <td>

                                        @user.CreatedAt.ToString("dd-MM-yyyy")

                                    </td>
                                   
                                    <td>

                                        @user.UpdatedAt.ToString("dd-MM-yyyy")

                                    </td>
                                    <td>


                                        <span class="badge
                                                       @(user.Role == "Developer" ? "bg-success" :
                                                                                              user.Role == "Student" ? "bg-info " :
                                                                                              user.Role == "Warden" ? "bg-warning" :
                                                                                                                                            "bg-info")">

                                    @user.Role

                                        </span>

                                    </td>


                                    <td>

                                        <span class="badge
                                                                @(user.IsActive ? "bg-success" : "bg-danger")">

                                            @(user.IsActive ? "Active" : "Inactive")

                                        </span>

                                    </td>

                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">

                                            <a asp-action="Edit"
                                               asp-route-UserId="@user.UserId"
                                               class="btn btn-warning btn-sm">
                                                ✏ Edit
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-UserId="@user.UserId"
                                                  method="post"
                                                  class="delete-form">

                                                <button type="button"
                                                        class="btn btn-danger btn-sm delete-btn"
                                                        data-message="Delete this user?">
                                                    🗑 Delete
                                                </button>

                                            </form>

                                        </div>
                                    </td>

                                </tr>

                            }
                        }
                        else
                        {

                            <tr>

                                <td colspan="8"
                                    class="text-muted">

                                    No User Found

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>


        <!-- FOOTER -->
        <div class="card-footer text-center text-muted">

            Total Users :
            @(Model?.Count() ?? 0)

        </div>

    </div>


    <!-- BACK TO TOP -->
    <button id="backToTopBtn"
            class="btn btn-outline-success btn-lg"
            style="position:fixed; bottom:40px; right:40px; display:none; border-radius:50%;">

        ⬆

    </button>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const backToTopBtn = document.getElementById("backToTopBtn");

        // Show button after scrolling down 200px
        window.onscroll = function() {
            if (document.body.scrollTop > 40 || document.documentElement.scrollTop > 40) {
                backToTopBtn.style.display = "block";
            } else {
                backToTopBtn.style.display = "none";
            }
        };

        // Smooth scroll to top on click
        backToTopBtn.addEventListener("click", function() {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    });
</script>

<!-- SEARCH + HIGHLIGHT SCRIPT FOR  -->
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("searchInput");
        const searchBtn = document.getElementById("searchBtn");
        const table = document.getElementById("userTable"); // ✅ correct id
        const tbody = table.getElementsByTagName("tbody")[0];
        const rows = tbody.getElementsByTagName("tr");

        function searchTable() {

            const filter = searchInput.value.toLowerCase();

            for (let i = 0; i < rows.length; i++) {

                const cells = rows[i].getElementsByTagName("td");
                let rowText = "";

                // reset highlight + build text
                for (let c = 0; c < cells.length - 1; c++) {

                    cells[c].innerHTML = cells[c].innerText;

                    rowText += cells[c].innerText.toLowerCase() + " ";
                }

                if (rowText.includes(filter)) {

                    rows[i].style.display = "";

                    // highlight
                    if (filter.length > 0) {

                        for (let c = 0; c < cells.length - 1; c++) {

                            const regex = new RegExp(`(${filter})`, "gi");

                            // cells[c].innerHTML =
                            //     cells[c].innerText.replace(regex, "<mark>$1</mark>");
                            cells[c].innerHTML = cells[c].innerText.replace(regex, "<span class='highlight'>$1</span>");
                        }
                    }

                }
                else {

                    rows[i].style.display = "none";

                }

            }

        }

        searchInput.addEventListener("keyup", searchTable);

        searchBtn.addEventListener("click", searchTable);

    });
</script>
<style>
    .highlight {
        background-color: white;
        color: red;
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.querySelectorAll(".delete-btn").forEach(button => {
        button.addEventListener("click", function () {

            let form = this.closest("form");
            let message = this.getAttribute("data-message") || "Are you sure?";

            Swal.fire({
                title: "Are you sure?",
                text: message,
                icon: "warning",
                position: "top", // 👈 top popup
                showCancelButton: true,
                confirmButtonColor: "#28a745",
                cancelButtonColor: "#dc3545",
                confirmButtonText: "Yes, delete it!",
                cancelButtonText: "Cancel"
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });

        });
    });
</script>