@model IEnumerable<Hostel_Consume_2026.Models.WardenModel>

@{
    ViewData["Title"] = "Warden List";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            title: "Success!",
            text: "@TempData["Success"]",
            icon: "success",
            position: "top",
            timer: 2000,
            timerProgressBar: true,
            showConfirmButton: false
        });
    </script>
}

<div class="container mt-5">
    <div class="card shadow-lg">

        <!-- CARD HEADER -->
        <div class="card-header bg-success text-white">
            <div class="row align-items-center">

                <!-- LEFT : Title -->
                <div class="col-md-4">
                    <h4 class="mb-0 text-white">🧑‍✈️ Warden Record</h4>
                </div>

                <!-- CENTER : Search -->
                <div class="col-md-4 text-center">
                    <div class="input-group input-group-sm justify-content-center" style="max-width: 300px;">
                        <input type="text"
                               class="form-control"
                               id="searchInput"
                               placeholder="Search Warden">
                        <button class="btn btn-light" type="button" id="searchBtn">🔍</button>
                    </div>
                </div>

                <!-- RIGHT : Buttons -->
                <div class="col-md-4 text-end">
                    <a asp-action="ExportToExcel" class="btn btn-light btn-sm me-2">⬇ Excel</a>
                    <a asp-action="Add" class="btn btn-light btn-sm">+ Add New Warden</a>
                </div>

            </div>
        </div>

        <!-- CARD BODY -->
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle text-center" id="wardenTable">
                    <thead class="table-secondary">
                        <tr>
                            <th>Warden ID</th>
                            <th>Warden Name</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Joining Date</th>
                            <th>Experience (Years)</th>
                            <th>Status</th>
                            <th width="190">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var warden in Model)
                            {
                                <tr>
                                    <td>@warden.Warden_id</td>
                                    <td>@warden.FirstName @warden.LastName</td>
                                    <td>@warden.Gender</td>
                                    <td>@warden.Phone</td>
                                    <td>@warden.Email</td>
                                    <td>@warden.JoiningDate.ToString("dd-MM-yyyy")</td>
                                    <td>@warden.ExperienceYears</td>
                                    <td>
                                        <span class="badge @(warden.Status ? "bg-success" : "bg-danger")">
                                            @(warden.Status ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">

                                            <a asp-action="Edit"
                                               asp-route-Warden_id="@warden.Warden_id"
                                               class="btn btn-warning btn-sm">
                                                ✏ Edit
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-Warden_id="@warden.Warden_id"
                                                  method="post"
                                                  class="m-0 delete-form">

                                                <button type="button"
                                                        class="btn btn-danger btn-sm delete-btn"
                                                        data-message="Are you sure you want to delete this warden?">
                                                    🗑 Delete
                                                </button>

                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-muted">No warden records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- CARD FOOTER -->
        <div class="card-footer text-muted text-center">
            Total Wardens: @(Model?.Count() ?? 0)
        </div>
    </div>
    <!-- Back to Top Button -->
    <button id="backToTopBtn" title="Go to top"
            class="btn btn-outline-success btn-lg"
            style="position: fixed; bottom: 40px; right: 40px; display: none; z-index: 1000; border-radius: 50%;">
        ⬆
    </button>
</div>
</div>

<!-- SEARCH + HIGHLIGHT SCRIPT -->
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("searchInput");
        const searchBtn = document.getElementById("searchBtn");
        const table = document.getElementById("wardenTable");
        const tbody = table.getElementsByTagName("tbody")[0];
        const rows = tbody.getElementsByTagName("tr");

        function searchTable() {
            const filter = searchInput.value.toLowerCase();

            for (let i = 0; i < rows.length; i++) {

                const cells = rows[i].getElementsByTagName("td");
                let rowText = "";

                // Build row text excluding last column (Actions)
                for (let c = 0; c < cells.length - 1; c++) {
                    // Reset highlights
                    cells[c].innerHTML = cells[c].innerText;
                    rowText += cells[c].innerText.toLowerCase() + " ";
                }

                if (rowText.includes(filter)) {
                    rows[i].style.display = "";

                    // Highlight matched text
                    if (filter.length > 0) {
                        for (let c = 0; c < cells.length - 1; c++) {
                            const regex = new RegExp(`(${filter})`, "gi");
                            // cells[c].innerHTML = cells[c].innerText.replace(regex, "<mark>$1</mark>");
                            cells[c].innerHTML = cells[c].innerText.replace(regex, "<span class='highlight'>$1</span>");
                        }
                    }
                } else {
                    rows[i].style.display = "none";
                }
            }
        }

        // Live search
        searchInput.addEventListener("keyup", searchTable);

        // Search on button click
        searchBtn.addEventListener("click", searchTable);

    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const backToTopBtn = document.getElementById("backToTopBtn");

        // Show button after scrolling down 200px
        window.onscroll = function() {
            if (document.body.scrollTop > 40 || document.documentElement.scrollTop > 40) {
                backToTopBtn.style.display = "block";
            } else {
                backToTopBtn.style.display = "none";
            }
        };

        // Smooth scroll to top on click
        backToTopBtn.addEventListener("click", function() {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    });
</script>
<style>
    .highlight {
        background-color: white;
        color: red;
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.querySelectorAll(".delete-btn").forEach(button => {
        button.addEventListener("click", function () {

            let form = this.closest("form");
            let message = this.getAttribute("data-message") || "Are you sure?";

            Swal.fire({
                title: "Are you sure?",
                text: message,
                icon: "warning",
                position: "top", // 👈 top popup
                showCancelButton: true,
                confirmButtonColor: "#28a745",
                cancelButtonColor: "#dc3545",
                confirmButtonText: "Yes, delete it!",
                cancelButtonText: "Cancel"
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });

        });
    });
</script>