@model Hostel_Consume_2026.Models.RoomBookingModel

@{
    ViewData["Title"] = Model.Booking_Id == 0 ? "Add Booking" : "Edit Booking";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

<div class="container mt-5">
    <div class="card shadow-lg">

        <!-- CARD HEADER -->
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">

            <!-- BACK BUTTON -->
            <a asp-action="Index" class="btn btn-light btn-sm">
                ← Back
            </a>

            <h4 class="mb-0 text-white">
                @(Model.Booking_Id == 0 ? "Add New Booking" : "Edit Booking")
            </h4>

        </div>

        <!-- CARD BODY -->
        <div class="card-body">
            <form asp-action="Add" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Booking_Id" />

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">

                    <!-- Guest Name -->
                    <div class="col-md-6">
                        <label asp-for="Guest_Name" class="form-label"></label>
                        <input asp-for="Guest_Name" class="form-control" />
                        <span asp-validation-for="Guest_Name" class="text-danger"></span>
                    </div>

                    <!-- Mobile -->
                    <div class="col-md-6">
                        <label asp-for="Mobile_No" class="form-label"></label>
                        <input asp-for="Mobile_No" class="form-control" />
                        <span asp-validation-for="Mobile_No" class="text-danger"></span>
                    </div>

                    <!-- Room Number -->
                    <div class="col-md-6">
                        <label asp-for="Room_Number" class="form-label"></label>
                        <input asp-for="Room_Number" class="form-control" />
                        <span asp-validation-for="Room_Number" class="text-danger"></span>
                    </div>

                    <!-- Booking Date -->
                    <div class="col-md-6">
                        <label asp-for="Booking_Date" class="form-label"></label>
                        <input asp-for="Booking_Date" type="date" class="form-control" />
                        <span asp-validation-for="Booking_Date" class="text-danger"></span>
                    </div>

                    <!-- Address -->
                    <div class="col-md-6">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <label asp-for="Booking_Status" class="form-label"></label>
                        <select asp-for="Booking_Status" class="form-select">
                            <option>Booked</option>
                            <option>CheckedIn</option>
                            <option>CheckedOut</option>
                            <option>Cancelled</option>
                        </select>
                        <span asp-validation-for="Booking_Status" class="text-danger"></span>
                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="mt-4 text-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                    <button type="submit" class="btn btn-success">
                        @(Model.Booking_Id == 0 ? "Save Booking" : "Update Booking")
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}