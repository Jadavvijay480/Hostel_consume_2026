@model IEnumerable<Hostel_Consume_2026.Models.StudentAttendanceModel>

@{
    ViewData["Title"] = "Student Attendance List";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            title: "Success!",
            text: "@TempData["Success"]",
            icon: "success",
            position: "top",
            timer: 2000,
            timerProgressBar: true,
            showConfirmButton: false
        });
    </script>
}

<div class="container mt-5">
    <div class="card shadow-lg">

        <!-- CARD HEADER -->
        <div class="card-header bg-success text-white">
            <div class="row align-items-center">

                <!-- LEFT : Title -->
                <div class="col-md-4">
                    <h4 class="mb-0 text-white">📅 Student Attendance Record</h4>
                </div>

                <!-- CENTER : Search -->
                <div class="col-md-4 text-center">
                    <div class="input-group input-group-sm justify-content-center" style="max-width: 300px;">
                        <input type="text"
                               class="form-control"
                               id="searchInput"
                               placeholder="Search Attendance">
                        <button class="btn btn-light" type="button" id="searchBtn">🔍</button>
                    </div>
                </div>

                <!-- RIGHT : Buttons -->
                <div class="col-md-4 text-end">
                    <a asp-action="ExportToExcel" class="btn btn-light btn-sm me-2">⬇ Excel</a>
                    <a asp-action="Add" class="btn btn-light btn-sm">+ Add Attendance</a>
                </div>

            </div>
        </div>

        <!-- CARD BODY -->
        <div class="card-body">
            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle text-center"
                       id="attendanceTable">

                    <thead class="table-secondary">
                        <tr>
                          
                            <th>Attendance ID</th>
                            <th>Student ID</th>
                            <th>AttendanceDate</th>
                            <th>Place</th>
                            <th>Remarks</th>
                            <th>Created At</th>
                            <th>Status</th>
                            <th width="190">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.Attendance_id</td>
                                    <td>@item.Student_id</td>
                                    <td>@item.AttendanceDate.ToString("dd-MM-yyyy")</td>

                                   

                                    <td>@item.Place</td>
                                    <td>@item.Remarks</td>
                                    <td>@item.CreatedAt.ToString("dd-MM-yyyy")</td>
                                    <td>
                                        <span class="badge
                                                        @(item.Status == "Present" ? "bg-success" :
                                                                                                                                      item.Status == "Absent" ? "bg-danger" :
                                                                                                                                      item.Status == "Leave" ? "bg-warning text-dark" :
                                                                                                                                      "bg-secondary")">

                                               @item.Status
                                        </span>
                                    </td>

                                    <td>
                                        <div class="d-flex justify-content-center gap-2">

                                            <a asp-action="Edit"
                                               asp-route-Attendance_id="@item.Attendance_id"
                                               class="btn btn-warning btn-sm">
                                                ✏ Edit
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-Attendance_id="@item.Attendance_id"
                                                  method="post"
                                                  class="delete-form">

                                                <button type="button"
                                                        class="btn btn-danger btn-sm delete-btn"
                                                        data-message="Are you sure you want to delete this record?">
                                                    🗑 Delete
                                                </button>

                                            </form>

                                        </div>
                                    </td>

                                </tr>
                                                }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-muted">
                                    No attendance records found.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        </div>

        <!-- FOOTER -->
        <div class="card-footer text-muted text-center">
            Total Records : @(Model?.Count() ?? 0)
        </div>

    </div>

    <!-- Back To Top -->
    <button id="backToTopBtn"
            class="btn btn-outline-success btn-lg"
            style="position: fixed; bottom: 40px; right: 40px; display: none; border-radius: 50%;">
        ⬆
    </button>

</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const backToTopBtn = document.getElementById("backToTopBtn");

        // Show button after scrolling down 200px
        window.onscroll = function() {
            if (document.body.scrollTop > 40 || document.documentElement.scrollTop > 40) {
                backToTopBtn.style.display = "block";
            } else {
                backToTopBtn.style.display = "none";
            }
        };

        // Smooth scroll to top on click
        backToTopBtn.addEventListener("click", function() {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    });
</script>

<!-- SEARCH + HIGHLIGHT SCRIPT FOR  -->
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("searchInput");
        const searchBtn = document.getElementById("searchBtn");
        const table = document.getElementById("attendanceTable"); // ✅ correct id
        const tbody = table.getElementsByTagName("tbody")[0];
        const rows = tbody.getElementsByTagName("tr");

        function searchTable() {

            const filter = searchInput.value.toLowerCase();

            for (let i = 0; i < rows.length; i++) {

                const cells = rows[i].getElementsByTagName("td");
                let rowText = "";

                // reset highlight + build text
                for (let c = 0; c < cells.length - 1; c++) {

                    cells[c].innerHTML = cells[c].innerText;

                    rowText += cells[c].innerText.toLowerCase() + " ";
                }

                if (rowText.includes(filter)) {

                    rows[i].style.display = "";

                    // highlight
                    if (filter.length > 0) {

                        for (let c = 0; c < cells.length - 1; c++) {

                            const regex = new RegExp(`(${filter})`, "gi");

                            cells[c].innerHTML =
                                // cells[c].innerText.replace(regex, "<mark>$1</mark>");
                                cells[c].innerText.replace(regex, "<span class='highlight'>$1</span>");
                        }
                    }

                }
                else {

                    rows[i].style.display = "none";

                }

            }

        }

        searchInput.addEventListener("keyup", searchTable);

        searchBtn.addEventListener("click", searchTable);

    });
</script>
<style>
    .highlight {
        background-color: white;
        color: red;
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.querySelectorAll(".delete-btn").forEach(button => {
        button.addEventListener("click", function () {

            let form = this.closest("form");
            let message = this.getAttribute("data-message") || "Are you sure?";

            Swal.fire({
                title: "Are you sure?",
                text: message,
                icon: "warning",
                position: "top", // 👈 top popup
                showCancelButton: true,
                confirmButtonColor: "#28a745",
                cancelButtonColor: "#dc3545",
                confirmButtonText: "Yes, delete it!",
                cancelButtonText: "Cancel"
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });

        });
    });
</script>