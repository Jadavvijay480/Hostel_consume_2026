@model Hostel_Consume_2026.Models.StudentAttendanceModel

@{
    ViewData["Title"] = Model.Attendance_id == 0 ? "Add Attendance" : "Edit Attendance";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

<div class="container mt-5">
    <div class="card shadow-lg">

        <!-- HEADER -->
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">

            <a asp-action="Index" class="btn btn-light btn-sm">
                ← Back
            </a>

            <h4 class="mb-0 text-white">
                @(Model.Attendance_id == 0 ? "Add Student Attendance" : "Edit Student Attendance")
            </h4>

        </div>

        <!-- BODY -->
        <div class="card-body">

            <form asp-action="Add" method="post">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Attendance_id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">

                    <!-- Student ID -->
                    <div class="col-md-6">
                        <label asp-for="Student_id" class="form-label"></label>
                        <input asp-for="Student_id" class="form-control" />
                        <span asp-validation-for="Student_id" class="text-danger"></span>
                    </div>

                    <!-- Attendance Date -->
                    <div class="col-md-6">
                        <label asp-for="AttendanceDate" class="form-label"></label>
                        <input asp-for="AttendanceDate" type="date" class="form-control" />
                        <span asp-validation-for="AttendanceDate" class="text-danger"></span>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="">Select Status</option>
                            <option>Present</option>
                            <option>Absent</option>
                            <option>Leave</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <!-- Place -->
                    <div class="col-md-6">
                        <label asp-for="Place" class="form-label"></label>
                        <input asp-for="Place" class="form-control" />
                        <span asp-validation-for="Place" class="text-danger"></span>
                    </div>

                    <!-- Remarks -->
                    <div class="col-md-12">
                        <label asp-for="Remarks" class="form-label"></label>
                        <textarea asp-for="Remarks" class="form-control"></textarea>
                        <span asp-validation-for="Remarks" class="text-danger"></span>
                    </div>

                </div>

                <!-- BUTTON -->
                <div class="mt-4 text-end">

                    <a asp-action="Index" class="btn btn-secondary me-2">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-success">
                        @(Model.Attendance_id == 0 ? "Save Attendance" : "Update Attendance")
                    </button>

                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}