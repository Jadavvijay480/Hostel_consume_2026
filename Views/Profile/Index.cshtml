@model List<Hostel_Consume_2026.Models.StudentModel>

@* <h1 class="app-page-title">Student Profile</h1> *@
<div class="container mt-4 mb-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap">

        <!-- Title -->
        <h2 class="mb-2">Student Profile</h2>

        <!-- Search Bar -->
        <div class="d-flex">
            <input type="text" id="searchInput"
                   class="form-control me-2"
                   placeholder="Search student..." />

            <button class="btn btn-primary text-white" onclick="searchStudent()">
                Search
            </button>
        </div>

    </div>
</div>

<div class="container mt-5">
    <div class="row">

        @foreach (var student in Model)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100 text-center" style="border-radius: 15px;">
                    <div class="card-body">

                        @* <img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava2-bg.webp"
                             class="rounded-circle img-fluid mb-3" style="width: 80px;" /> *@
                        <img src="@(student.Gender == "Female"
                                 ? "https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava2-bg.webp"
                                 : "https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3-bg.webp")"
                         class="rounded-circle img-fluid mb-3"
                         style="width: 80px;" />

                        <h5>@student.FullName</h5>
                        <p class="text-muted">@student.Gender</p>

                        <p class="small">📞 @student.Phone</p>
                        <p class="small">📧 @student.Email</p>
                        <p class="small">🏠 @student.Address</p>

                        <a asp-controller="Student"
                           asp-action="Edit"
                           asp-route-Student_id="@student.Student_id"
                           class="btn btn-primary btn-sm mt-2 text-white">
                            View Profile
                        </a>

                    </div>
                </div>
            </div>
        }

    </div>
</div>
<script>
    document.getElementById("searchInput").addEventListener("keyup", function () {
        let input = this.value.toLowerCase();
        let cards = document.querySelectorAll(".card");

        cards.forEach(card => {
            let text = card.innerText.toLowerCase();
            card.parentElement.style.display = text.includes(input) ? "block" : "none";
        });
    });
</script>
